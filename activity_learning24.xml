<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Status Bar Space -->
    <View
        android:layout_width="match_parent"
        android:layout_height="28dp" />

    <!-- Top Bar with eye-off icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_eye_off"
            android:tint="#CCCCDD"
            android:contentDescription="Hide" />

    </LinearLayout>

    <!-- Centered Empty State -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp">

        <!-- Illustration -->
        <ImageView
            android:layout_width="200dp"
            android:layout_height="180dp"
            android:src="@drawable/img_no_network"
            android:scaleType="fitCenter"
            android:contentDescription="No network illustration" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Network!"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginTop="28dp"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please check your internet&#10;connection and try again"
            android:textSize="13sp"
            android:textColor="#B0B0C0"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

        <!-- Try Again Button -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Try again"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="@drawable/button_blue_rounded"
            android:layout_marginTop="36dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>