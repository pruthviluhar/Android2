<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background soft circle -->
    <item
        android:gravity="center"
        android:bottom="20dp">
        <shape android:shape="oval">
            <solid android:color="#F0F2FF" />
            <size android:width="160dp" android:height="140dp" />
        </shape>
    </item>

    <!-- Document shape (white card behind person) -->
    <item
        android:gravity="center"
        android:bottom="30dp"
        android:left="20dp"
        android:right="20dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="#E8EAFF" />
            <size android:width="100dp" android:height="120dp" />
        </shape>
    </item>

</layer-list>