<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Status Bar Space -->
    <View
        android:layout_width="match_parent"
        android:layout_height="28dp" />

    <!-- Top Bar with eye-off icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="8dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_eye_off"
            android:contentDescription="Hide"
            app:tint="#CCCCDD" />

    </LinearLayout>

    <!-- Centered Empty State -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="40dp">

        <!-- Illustration -->
        <ImageView
            android:layout_width="220dp"
            android:layout_height="180dp"
            android:src="@drawable/img_no_notifications"
            android:scaleType="fitCenter"
            android:contentDescription="No notifications illustration" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Notifications yet!"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:layout_marginTop="24dp"
            android:gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="We'll notify you once we have&#10;something for you"
            android:textSize="13sp"
            android:textColor="#B0B0C0"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5" />

    </LinearLayout>

</LinearLayout>