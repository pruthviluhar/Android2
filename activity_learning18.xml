<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#3D3F5A">

    <!-- Modal Card -->
    <androidx.cardview.widget.CardView android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="80dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#FFFFFF"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clocking in!"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOOD JOB!"
                android:textSize="12sp"
                android:textColor="#9E9EB8"
                android:letterSpacing="0.08"
                android:layout_marginTop="4dp" />

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <!-- Learned Today -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Learned today"
                        android:textSize="12sp"
                        android:textColor="#9E9EB8" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="46"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" min"
                            android:textSize="14sp"
                            android:textColor="#9E9EB8"
                            android:layout_gravity="bottom"
                            android:layout_marginBottom="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Totally Hours -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="totally hours"
                        android:textSize="12sp"
                        android:textColor="#9E9EB8" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="468"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A2E" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" hrs"
                            android:textSize="14sp"
                            android:textColor="#9E9EB8"
                            android:layout_gravity="bottom"
                            android:layout_marginBottom="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Totally Days -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Totally days"
                    android:textSize="12sp"
                    android:textColor="#9E9EB8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="554"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" days"
                        android:textSize="14sp"
                        android:textColor="#9E9EB8"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EBEBF5"
                android:layout_marginTop="20dp" />

            <!-- Record of this week label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record of this week"
                android:textSize="12sp"
                android:textColor="#9E9EB8"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp" />

            <!-- Week Day Circles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <!-- Day 1 - Filled -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="1"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_filled"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 2 - Filled -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="2"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_filled"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 3 - Filled -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="3"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_filled"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 4 - Filled -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="4"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/circle_filled"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 5 - Empty -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="5"
                    android:textSize="14sp"
                    android:textColor="#C4C4D4"
                    android:gravity="center"
                    android:background="@drawable/circle_empty"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 6 - Empty -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="6"
                    android:textSize="14sp"
                    android:textColor="#C4C4D4"
                    android:gravity="center"
                    android:background="@drawable/circle_empty"
                    android:layout_marginHorizontal="4dp" />

                <!-- Day 7 - Empty -->
                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="7"
                    android:textSize="14sp"
                    android:textColor="#C4C4D4"
                    android:gravity="center"
                    android:background="@drawable/circle_empty"
                    android:layout_marginHorizontal="4dp" />

            </LinearLayout>

            <!-- Share Button -->
            <androidx.appcompat.widget.AppCompatButton
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Share"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/button_blue_rounded"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Close Button -->
    <ImageButton
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_close"
        android:background="@drawable/circle_close_button"
        android:contentDescription="Close"
        app:tint="#FFFFFF" />

</FrameLayout>